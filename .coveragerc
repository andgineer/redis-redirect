[run]
relative_files = true
omit =
    */tests/*
    */*_check.py
    */__init__.py
    */conftest.py
    */.tox/*
    */.venv/*
    */.eggs/*
    */docs/*
    */build/*
    */dist/*
    */.git/*
    */.github/*
    */.vscode/*
    */.pytest_cache/*
    # Example/script file, not a library component
    */redis_redirect/pubsub.py
    # Single constant, not worth testing
    */redis_redirect/version.py
